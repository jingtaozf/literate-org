{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(emacs:*)",
      "Bash(poetry run python -m pytest:*)",
      "Bash(poetry run python:*)",
      "Bash(poetry install:*)",
      "Bash(poetry lock:*)",
      "Bash(make lint:*)",
      "Bash(make check-structure:*)",
      "Bash(make check-nl-outline:*)",
      "Bash(make index:*)",
      "Bash(make tangle:*)",
      "Bash(make secret-scan:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-tangled-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/tangle-org-buffer.sh"
          }
        ]
      }
    ]
  }
}
